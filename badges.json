{
  "filters": [
    {
      "id": "dolby-vision",
      "groupId": "dolby-video",
      "name": "Dolby Vision",
      "pattern": "(?i)\\b(dolby\\s*vision|dovi|dv)\\b",
      "imageURL": "https://raw.githubusercontent.com/leonevz/Elite-Badges/main/Badges/dolby_vision.png",
      "tagColor": "#00000000",
      "borderColor": "#00000000",
      "textColor": "#00000000",
      "tagStyle": "filled and bordered",
      "isEnabled": true,
      "type": "filter"
    },
    {
      "id": "hdr10-plus",
